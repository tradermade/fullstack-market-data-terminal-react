# ── Server-side keys (read by server.js — no VITE_ prefix needed) ──
TRADERMADE_API_KEY=your_rest_api_key
TRADERMADE_WS_API_KEY=your_websocket_api_key

# ── Browser-bundled values (Vite requires the VITE_ prefix) ──
# Logo image shown in the top-left of the terminal. URL or path under /public.
# Examples:
#   VITE_LOGO_URL=https://your-domain.com/logo.png
#   VITE_LOGO_URL=/logo.svg          (drop logo.svg into the public/ folder)
# Leave unset to use the default TraderMade logo.
# VITE_LOGO_URL=

# Optional. Override the WebSocket proxy URL the browser connects to.
# Useful only if your frontend dev server runs on a different host than the
# backend (e.g. running Vite dev on localhost:5173 while the backend is elsewhere).
# VITE_PROXY_WS_URL=ws://localhost:3001
